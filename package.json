{
  "name": "restaurant-dashboard-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "postbuild": "node -e \"const fs=require('fs'),path=require('path');const src='dist/restaurant-dashboard-angular/browser';const dst='../restaurant-desktop/src/browser';if(!fs.existsSync(src)){console.error('Source not found:',src);process.exit(1);}fs.rmSync(dst,{recursive:true,force:true});fs.cpSync(src,dst,{recursive:true});console.log('Copied Angular build to',dst);\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "source-map-analyzer": "ng build --configuration=production --source-map",
    "source-map-explorer": "source-map-explorer dist/restaurant-dashboard-angular/browser/**/*.js"
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular/common": "^21.1.6",
    "@angular/compiler": "^21.1.6",
    "@angular/core": "^21.1.6",
    "@angular/forms": "^21.1.6",
    "@angular/platform-browser": "^21.1.6",
    "@angular/router": "^21.1.6",
    "@ng-select/ng-select": "^21.2.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@primeuix/themes": "^2.0.2",
    "crypto-js": "^4.2.0",
    "ng-qrcode": "^21.0.0",
    "ngx-countdown": "^21.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.1",
    "rxjs": "~7.8.0",
    "simple-keyboard": "^3.8.108",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.3",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.1.6",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/crypto-js": "^4.2.2",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
