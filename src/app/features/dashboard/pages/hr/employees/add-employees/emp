    <div class=" flex-1 grid grid-col-1 md:grid-cols-15 gap-[24px] gap-y-[20px]">
        <div class="col-span-3">
            <label for="jopNum" >الرقم الوظيفي</label>
            <input type="text" id="JobNum" placeholder="الرقم الوظيفي">
        </div>
        <div class="col-span-4">
            <label for="baseNum" >الرقم الاساسي</label>
            <input type="text" id="baseNum" placeholder="الرقم الاساسي">
        </div>
        <div class="col-span-4">
            <label for="badal" >البدلات</label>
            <!-- <input type="text" id="badal" placeholder="البدلات"> -->
             <ng-select [items]="AllowancesList" [bindLabel]="'name'" [bindValue]="'id'" [placeholder]="'أختر'" multiple></ng-select>
        </div>
        <div class="col-span-4">
            <label for="salary" >الرواتب</label>
            <input type="text" id="salary" placeholder="الرواتب">
        </div>

        <div class="col-span-3">
             <label for="section" >القسم</label>
           <ng-select [items]="sectionsData" [bindLabel]="'name'" [bindValue]="'id'" [placeholder]="'أختر'"
              [loading]="loading"
             (scrollToEnd)="loadMoreSections()"
           ></ng-select>
        </div>
        <div class="col-span-4">
             <label for="arabicName" >الأسم العربي</label>
            <input type="text" name="arabicName" id="arabicName" placeholder="الأسم العربي">
        </div>
        <div class="col-span-4">
             <label for="englishName" >english name</label>
            <input type="text" name="arabicName" id="englishName" placeholder="english name">
        </div>
            <div class="col-span-4">
             <label for="phoneNumber" >رقم الجوال</label>
            <input type="text" name="phoneNumber" id="phoneNumber" placeholder="رقم الجوال">
        </div>
         
    </div>

  </div>


</form>
<form class="box_header mb-7" [formGroup]="formAttachment">
  <div class="title"> بيانات اضافيه </div>



  <div class="grid grid-cols-1 lg:grid-cols-16 gap-[24px] my-[8px] mb-[20px]">


       

    <div class="col-span-12 md:col-span-4">
        <label for="idNumber" >رقم الهويه / الاقامه</label>
        <input type="text" id="idNumber" placeholder="رقم الهويه / الاقامه" >
    </div>
    <div class="col-span-12 md:col-span-4">
      <app-input-attachment [label]="'مرفق الهويه / الاقامه'"
      formControlName="attachment"
      ></app-input-attachment>
    </div>
     <div class="col-span-12 md:col-span-4">
            <label for="addDate" >التاريخ</label>
            <p-datepicker  [iconDisplay]="'input'" [placeholder]="'التاريخ'" [showIcon]="true" inputId="addDate" />
            <!-- <input type="text" id="document" placeholder="التاريخ" placeholder="0.00"> -->
        </div>
         <div class="col-span-12 md:col-span-4">
      <app-input-attachment [label]="'مرفق التامين الطبي'"
    
      ></app-input-attachment>
    </div>
    <div class="col-span-12 md:col-span-4">
        <label for="document" >رقم الصرافه</label>
        <input type="text" id="document" numMar placeholder="رقم الصرافه">
    </div>
    
      <div class="col-span-12 md:col-span-4">
      <app-input-attachment [label]="'مرفق الصرافه'"
    
      ></app-input-attachment>
    </div>

     <div class="col-span-12 md:col-span-4">
        <label for="numMar" >رقم الجواز</label>
        <input type="text" id="numMar" placeholder="رقم الجواز">
    </div>

      <div class="col-span-12 md:col-span-4">
      <app-input-attachment [label]="'مرفق الجواز'"
    
      ></app-input-attachment>
    </div>

    <div class="col-span-12 md:col-span-4">
        <label for="numBor" >رقم الحدود</label>
        <input type="text" id="numBor" placeholder="رقم الحدود">
    </div>

      <div class="col-span-12 md:col-span-4">
      <app-input-attachment [label]="'مرفق الحدود'"
    
      ></app-input-attachment>
    </div>

    
    <div class="col-span-12 md:col-span-4">
        <label for="Nationality" >الجنسية</label>
        <input type="text" id="Nationality" placeholder="الجنسية">
    </div>
    <div class="col-span-12 md:col-span-4">
        <label for="work" >المهنه</label>
        <input type="text" id="work" placeholder="المهنه">
    </div>

      <div class="col-span-12 md:col-span-4">
            <label for="Birth" >تاريخ الميلاد</label>
            <p-datepicker  [iconDisplay]="'input'" [placeholder]="'تاريخ الميلاد'" [showIcon]="true" inputId="Birth" />
            <!-- <input type="text" id="document" placeholder="التاريخ" placeholder="0.00"> -->
        </div>

      <div class="col-span-12 md:col-span-4">
            <label for="live" >تاريخ مباشره العمل</label>
            <p-datepicker  [iconDisplay]="'input'" [placeholder]="'تاريخ مباشره العمل'" [showIcon]="true" inputId="live" />
            <!-- <input type="text" id="document" placeholder="التاريخ" placeholder="0.00"> -->
        </div>

      <div class="col-span-12 md:col-span-4">
            <label for="Replay" >تاريخ العوده من الاجازه</label>
            <p-datepicker  [iconDisplay]="'input'" [placeholder]="'تاريخ العوده من الاجازه'" [showIcon]="true" inputId="Replay" />
            <!-- <input type="text" id="document" placeholder="التاريخ" placeholder="0.00"> -->
        </div>

      <div class="col-span-12 md:col-span-4">
            <label for="endContract" >تاريخ إنهاء العقد</label>
            <p-datepicker  [iconDisplay]="'input'" [placeholder]="'تاريخ إنهاء العقد'" [showIcon]="true" inputId="endContract" />
            <!-- <input type="text" id="document" placeholder="التاريخ" placeholder="0.00"> -->
        </div>

        
            <div class="col-span-12 md:col-span-4">
      <app-input-attachment [label]="'مرفق انهاء العقد'"
    
      ></app-input-attachment>
    </div>
        <div class="col-span-12 md:col-span-12">
        <label for="address" >العنوان</label>
        <input type="text" id="address" placeholder="العنوان">
    </div>





  
  

      

  

  </div>


</form>




