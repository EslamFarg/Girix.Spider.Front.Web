<div class="flex justify-between flex-wrap mb-[25px] sticky top-[60px] pt-[10px] mt-[10px] bg-[var(--color-bg)] z-1">
    <div>
        
        <h2 class="text-[var(--color-primary)] text-[20px] font-[700]">الموظفين</h2>
      <div class="flex items-center flex-wrap gap-5 my-4
      [&>*]:w-[104px]  [&>*]:h-[32px]  
      ">
          <button class="btn btn-primary">حفظ</button>
          <button class="btn">جديد</button>
          <button class="btn">حذف</button>
          <button class="btn">طباعه</button>
        </div>
    </div>

   <div class="explorer_button">
    <button [routerLink]="'/hr/employees/explorer'"  class="btn btn-primary" style="width:245px !important;">مستكشف  الموظفين </button>

   </div>
    
</div>


